# Bloquear acesso HTTP direto a arquivos de configuração e credenciais

# Bloquear db.php, .env e db_config.ini (credenciais e configuração sensível)
<FilesMatch "^(db\.php|\.env|db_config\.ini)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquear diretorios internos da nova arquitetura
# IMPORTANTE: actions/ NAO entra aqui pois e onde forms postam (cliente_update, cliente_create, etc).
# Os actions ja tem protecao interna via Auth::isAdmin() + CSRF, nao precisam de bloqueio HTTP.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^core/ - [F,L]
    RewriteRule ^maintenance/ - [F,L]
</IfModule>
