# Bloquear acesso HTTP direto a arquivos de configuração e credenciais

# Bloquear db.php, .env e db_config.ini (credenciais e configuração sensível)
<FilesMatch "^(db\.php|\.env|db_config\.ini)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquear diretórios internos da nova arquitetura
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^core/ - [F,L]
    RewriteRule ^actions/ - [F,L]
    RewriteRule ^maintenance/ - [F,L]
</IfModule>
